generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String @unique
  username      String @unique
  password      String?
  provider      AuthProvider @default(CREDENTIALS)
  providerId    String?
  refreshToken  String?
  otp           String?
  otpvalidity   DateTime?
  files         File[]
  sign          Signature[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

enum AuthProvider {
  GOOGLE
  CREDENTIALS
}

model File{
  id            String @id  @default(cuid())
  fileurl       String? 
  user          User?   @relation(fields: [userId], references: [id])
  userId        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Signature{
  id            String @id  @default(cuid())
  signatureurl  String? 
  user          User?   @relation(fields: [userId], references: [id])
  userId        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}